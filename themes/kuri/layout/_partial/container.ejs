<div id="container" class="container"> 
    <div class="card"> 
     <div id="card-content" class="card-content"> 
      <center>
       <div class="logo"></div>
       <style>
        .logo {
	        width: 100px;
	        height: 100px;
	        margin-top: -50px;
	        border:1px soild white;
	        background: url('<%= theme.logo %>') no-repeat center;
	        border-radius: 50px;
	        background-size: 100px;
        }
       </style>
      </center> 
      <b class="nickname"><%= theme.nickname %></b> 
      <br /> 
      <b class="motto"><%= theme.motto %></b> 
     </div> 
    </div> 

    <div class="card" style="margin-top: 1%;"> 
     <div id="card-content" class="card-content"> 
      <div class="social">
        <% for (a in theme.social) { %>
        <a href="<%= theme.social[a][0] %>" target="_blank" style="display: flex; align-items: center; gap: 8px; margin: 6px 0; text-decoration: none; color: inherit;">
          <button class="mdui-btn mdui-btn-icon" mdui-tooltip="{content: '<%= theme.social[a][1] %>'}">
            <% if (theme.social[a][2].indexOf('.png') !== -1 || theme.social[a][2].indexOf('.jpg') !== -1) { %>
            <img src="<%= theme.social[a][2] %>" style="width: 24px; height: 24px; border-radius: 4px;">
            <% } else { %>
            <span class="<%= theme.social[a][2] %>"></span>
            <% } %>
          </button>
          <span style="font-size: 14px; color: #666;"><%= theme.social[a][1] %></span>
        </a>
       <% } %>
      </div> 
     </div> 
    </div> 

   </div> 